@model IEnumerable<TiendaTecnologica.Models.Producto>

@{
    var sub = ViewBag.Subcategoria as TiendaTecnologica.Models.Subcategoria;
    ViewData["Title"] = sub?.Nombre;
}

<div class="mb-4">
    <h2>@sub?.Nombre</h2>
    <p class="text-muted">Productos disponibles en esta subcategoría.</p>
</div>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 col-lg-3 mb-4">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@item.Nombre</h5>
                    <p class="text-muted mb-1">@item.Marca</p>
                    <p class="card-text small flex-grow-1">@item.Descripcion</p>
                    <p class="fw-bold fs-5">₡@item.Precio</p>

                    <a class="btn btn-outline-primary mt-auto"
                           asp-controller="Productos"
                           asp-action="Detalle"
                           asp-route-id="@item.IdProducto">
                        Ver producto
                    </a>
                </div>
            </div>
        </div>
    }
</div>