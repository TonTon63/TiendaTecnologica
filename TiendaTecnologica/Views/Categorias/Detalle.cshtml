@model TiendaTecnologica.ViewModels.CategoriaDetalleViewModel

@{
    ViewData["Title"] = Model.Categoria?.Nombre;
}

<div class="categoria-header mb-5">
    <div class="categoria-banner p-4 p-md-5 rounded-4 shadow-sm">
        <h1 class="fw-bold mb-2">@Model.Categoria?.Nombre</h1>
        <p class="text-muted mb-0 fs-5">@Model.Categoria?.Descripcion</p>
    </div>
</div>

<section class="mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0">Explora subcategorías</h3>
    </div>

    <div class="row g-4">
        @foreach (var sub in Model.Subcategorias)
        {
            <div class="col-6 col-md-4 col-lg-3 col-xl-2">
                <a asp-controller="Subcategorias"
                       asp-action="Detalle"
                       asp-route-id="@sub.IdSubcategoria"
                       class="text-decoration-none">
                    <div class="subcategoria-card h-100">
                        <div class="subcategoria-icon-wrap mx-auto mb-3">
                            <i class="bi @(string.IsNullOrWhiteSpace(sub.Icono) ? "bi-grid" : sub.Icono) subcategoria-icon"></i>
                        </div>

                        <h6 class="fw-semibold subcategoria-nombre mb-2">@sub.Nombre</h6>

                        <span class="subcategoria-link-text">Explorar</span>
                    </div>
                </a>
            </div>
        }
    </div>
</section>

<section class="mb-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h3 class="fw-bold mb-1">Productos destacados</h3>
            <p class="text-muted mb-0">Explora algunos productos seleccionados de esta categoría.</p>
        </div>
    </div>

    @if (Model.Productos.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model.Productos.Take(8))
            {
                <div class="col-sm-6 col-lg-4 col-xl-3">
                    <div class="card producto-card-catalogo h-100 border-0">

                        <div class="producto-img-wrapper">
                            <div class="producto-badges">
                                <span class="producto-badge-stock @(item.Stock > 0 ? "disponible" : "agotado")">
                                    @(item.Stock > 0 ? "Disponible" : "Agotado")
                                </span>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(item.ImagenUrl))
                            {
                                <img src="@item.ImagenUrl" alt="@item.Nombre" class="producto-img" loading="lazy" />
                            }
                            else
                            {
                                <div class="producto-imagen-placeholder d-flex align-items-center justify-content-center">
                                    <div class="producto-placeholder-content text-center">
                                        <div class="producto-placeholder-icon mb-2">
                                            <i class="bi bi-image"></i>
                                        </div>
                                        <span>Sin imagen</span>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="card-body d-flex flex-column">
                            <p class="producto-subcategoria mb-2 text-uppercase">
                                @item.Subcategoria?.Nombre
                            </p>

                            <h5 class="producto-titulo">@item.Nombre</h5>

                            <p class="producto-marca mb-3">
                                @(string.IsNullOrWhiteSpace(item.Marca) ? "Marca no especificada" : item.Marca)
                            </p>

                            <div class="producto-footer mt-auto">
                                <div class="producto-precio-wrap mb-3">
                                    <span class="producto-precio-label">Precio</span>
                                    <div class="producto-precio">
                                        ₡@item.Precio.ToString("N2")
                                    </div>
                                </div>

                                <div class="producto-actions">
                                    <a class="btn producto-btn w-100"
                                           asp-controller="Productos"
                                           asp-action="Detalle"
                                           asp-route-id="@item.IdProducto">
                                        Ver producto
                                    </a>

                                    <button type="button"
                                            class="btn producto-btn w-100 add-to-cart-btn"
                                            data-id="@item.IdProducto"
                                            data-name="@item.Nombre"
                                            data-price="@item.Precio"
                                            data-image="@item.ImagenUrl">
                                        Agregar al carrito
                                    </button>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-warning rounded-4">
                No hay productos disponibles en esta categoría.
            </div>
        </div>
    }
</section>