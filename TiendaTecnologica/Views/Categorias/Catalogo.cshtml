@model TiendaTecnologica.ViewModels.CategoriaDetalleViewModel

@{
    ViewData["Title"] = Model.Categoria?.Nombre;
}

<div class="mb-4">
    <h2>@Model.Categoria?.Nombre</h2>
    <p class="text-muted">Explora las subcategorías y productos disponibles.</p>
</div>

<div class="row mb-5">
    @foreach (var sub in Model.Subcategorias)
    {
        <div class="col-6 col-md-3 col-lg-2 mb-4 text-center">
            <a asp-controller="Subcategorias"
                   asp-action="Detalle"
                   asp-route-id="@sub.IdSubcategoria"
                   class="text-decoration-none text-dark">
                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto mb-2"
                     style="width: 110px; height: 110px;">
                    <span>@sub.Nombre</span>
                </div>
            </a>
        </div>
    }
</div>

<h4 class="mb-3">Productos destacados</h4>
<div class="row">
    @if (Model.Productos.Any())
    {
        @foreach (var item in Model.Productos)
        {
            <div class="col-md-4 col-lg-3 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body d-flex flex-column">
                        <p class="text-muted small mb-1">@item.Subcategoria?.Nombre</p>
                        <h5 class="card-title">@item.Nombre</h5>
                        <p class="text-muted mb-1">@item.Marca</p>
                        <p class="card-text small flex-grow-1">@item.Descripcion</p>
                        <p class="fw-bold fs-5">₡@item.Precio</p>
                        <p class="small">Stock: @item.Stock</p>

                        <a class="btn btn-outline-primary mt-auto"
                               asp-controller="Productos"
                               asp-action="Detalle"
                               asp-route-id="@item.IdProducto">
                            Ver producto
                        </a>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12">
            <div class="alert alert-warning">
                No hay productos disponibles en esta categoría.
            </div>
        </div>
    }
</div>