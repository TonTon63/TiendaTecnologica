@{
    ViewData["Title"] = "Sobre Nosotros";
}

<section class="page-hero-section py-5">
    <div class="container py-4">
        <div class="row align-items-center g-4">
            <div class="col-lg-7 fade-in-up">
                <span class="page-badge mb-3 d-inline-block">TechStore CR</span>
                <h1 class="page-title mb-3">Sobre Nosotros</h1>
                <p class="page-subtitle mb-0">
                    Somos una tienda enfocada en ofrecer tecnología moderna, confiable y accesible,
                    con una experiencia de compra clara, segura y profesional.
                </p>
            </div>

            <div class="col-lg-5 fade-in-up delay-1">
                <div class="info-glass-card h-100">
                    <h5 class="fw-bold mb-3">¿Qué encontrarás con nosotros?</h5>
                    <div class="info-line">✔ Productos tecnológicos seleccionados</div>
                    <div class="info-line">✔ Atención cercana y rápida</div>
                    <div class="info-line">✔ Compra segura y clara</div>
                    <div class="info-line mb-0">✔ Enfoque en calidad y confianza</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="container py-5">
    <div class="row g-4">
        <div class="col-lg-6 fade-in-up">
            <div class="content-card h-100">
                <h2 class="section-title mb-3">Quiénes somos</h2>
                <p>
                    En <strong>TechStore CR</strong> trabajamos para acercar la tecnología a más personas,
                    ofreciendo productos de distintas categorías como computadoras, periféricos,
                    audio, gaming, móviles, redes y más.
                </p>
                <p class="mb-0">
                    Nuestro objetivo es que cada cliente encuentre soluciones útiles, modernas
                    y con una presentación profesional, sin complicaciones al momento de explorar,
                    comparar y elegir.
                </p>
            </div>
        </div>

        <div class="col-lg-6 fade-in-up delay-1">
            <div class="content-card h-100">
                <h2 class="section-title mb-3">Nuestra propuesta</h2>
                <p>
                    Queremos ofrecer una tienda que combine diseño moderno, facilidad de uso
                    y una experiencia de compra seria, donde el cliente pueda navegar por categorías,
                    subcategorías y productos de forma clara.
                </p>
                <p class="mb-0">
                    Apostamos por una imagen confiable, una estructura ordenada y un servicio que
                    inspire seguridad desde el primer momento.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="container pb-5">
    <div class="row g-4">
        <div class="col-md-6 fade-in-up">
            <div class="mission-card h-100">
                <div class="mini-icon mb-3">🎯</div>
                <h3 class="section-title mb-3">Misión</h3>
                <p class="mb-0">
                    Brindar acceso a productos tecnológicos de calidad mediante una plataforma
                    moderna, organizada y confiable, ofreciendo una experiencia cómoda y clara
                    para cada cliente.
                </p>
            </div>
        </div>

        <div class="col-md-6 fade-in-up delay-1">
            <div class="mission-card h-100">
                <div class="mini-icon mb-3">🚀</div>
                <h3 class="section-title mb-3">Visión</h3>
                <p class="mb-0">
                    Convertirnos en una tienda tecnológica reconocida por su imagen profesional,
                    variedad de productos y experiencia digital atractiva, moderna y segura.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="container pb-5">
    <div class="text-center mb-5 fade-in-up">
        <h2 class="section-title">¿Por qué elegir TechStore CR?</h2>
        <p class="text-muted mb-0">Queremos que comprar tecnología se sienta fácil, moderno y confiable.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-3 fade-in-up">
            <div class="feature-card h-100 text-center">
                <div class="feature-icon mb-3">💻</div>
                <h5 class="fw-bold">Variedad</h5>
                <p class="mb-0">Múltiples categorías y productos para distintas necesidades.</p>
            </div>
        </div>

        <div class="col-md-3 fade-in-up delay-1">
            <div class="feature-card h-100 text-center">
                <div class="feature-icon mb-3">⚡</div>
                <h5 class="fw-bold">Experiencia moderna</h5>
                <p class="mb-0">Un sitio diseñado para navegar de forma cómoda y atractiva.</p>
            </div>
        </div>

        <div class="col-md-3 fade-in-up delay-2">
            <div class="feature-card h-100 text-center">
                <div class="feature-icon mb-3">🛡️</div>
                <h5 class="fw-bold">Confianza</h5>
                <p class="mb-0">Información clara sobre productos, procesos y soporte.</p>
            </div>
        </div>

        <div class="col-md-3 fade-in-up delay-3">
            <div class="feature-card h-100 text-center">
                <div class="feature-icon mb-3">📲</div>
                <h5 class="fw-bold">Atención</h5>
                <p class="mb-0">Canales de contacto para acompañar al cliente cuando lo necesite.</p>
            </div>
        </div>
    </div>
</section>