@{
    ViewData["Title"] = "Garantías";
}

<section class="page-hero-section py-5">
    <div class="container py-4">
        <div class="row align-items-center g-4">
            <div class="col-lg-7 fade-in-up">
                <span class="page-badge mb-3 d-inline-block">Respaldo y confianza</span>
                <h1 class="page-title mb-3">Garantías</h1>
                <p class="page-subtitle mb-0">
                    En TechStore CR buscamos ofrecer claridad y respaldo en cada compra.
                    Aquí encontrarás información general sobre nuestras condiciones de garantía
                    y el proceso de revisión de productos.
                </p>
            </div>

            <div class="col-lg-5 fade-in-up delay-1">
                <div class="info-glass-card h-100">
                    <h5 class="fw-bold mb-3">Resumen general</h5>
                    <div class="info-line">✔ Garantías sujetas al tipo de producto</div>
                    <div class="info-line">✔ Revisión previa del artículo</div>
                    <div class="info-line">✔ Aplican condiciones del fabricante o tienda</div>
                    <div class="info-line mb-0">✔ Atención por canales oficiales</div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="container py-5">
    <div class="row g-4">
        <div class="col-lg-6 fade-in-up">
            <div class="content-card h-100">
                <h2 class="section-title mb-3">Cobertura de garantía</h2>
                <p>
                    La garantía aplica según el tipo de producto, fabricante, marca
                    y condiciones específicas de venta. Algunos artículos cuentan con
                    garantía directa del fabricante, mientras que otros pueden ser gestionados
                    por la tienda según las políticas aplicables.
                </p>
                <p class="mb-0">
                    El tiempo de cobertura puede variar de un producto a otro, por lo que
                    es importante conservar comprobantes, empaques y cualquier información
                    relacionada con la compra.
                </p>
            </div>
        </div>

        <div class="col-lg-6 fade-in-up delay-1">
            <div class="content-card h-100">
                <h2 class="section-title mb-3">Qué puede cubrir</h2>
                <ul class="styled-list mb-0">
                    <li>Defectos de fábrica detectados dentro del período de cobertura.</li>
                    <li>Fallos de funcionamiento no causados por mal uso.</li>
                    <li>Problemas técnicos sujetos a validación por revisión.</li>
                    <li>Casos contemplados dentro de las condiciones del fabricante o proveedor.</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<section class="container pb-5">
    <div class="row g-4">
        <div class="col-md-4 fade-in-up">
            <div class="feature-card h-100 text-center">
                <div class="feature-icon mb-3">🧾</div>
                <h5 class="fw-bold">Comprobante</h5>
                <p class="mb-0">
                    Para cualquier trámite de garantía puede ser necesario presentar
                    comprobante de compra o información del pedido.
                </p>
            </div>
        </div>

        <div class="col-md-4 fade-in-up delay-1">
            <div class="feature-card h-100 text-center">
                <div class="feature-icon mb-3">🔍</div>
                <h5 class="fw-bold">Revisión</h5>
                <p class="mb-0">
                    Todo producto puede ser sometido a evaluación para determinar
                    si el caso aplica dentro de garantía.
                </p>
            </div>
        </div>

        <div class="col-md-4 fade-in-up delay-2">
            <div class="feature-card h-100 text-center">
                <div class="feature-icon mb-3">🛠️</div>
                <h5 class="fw-bold">Gestión</h5>
                <p class="mb-0">
                    La solución puede variar entre reparación, reemplazo o resolución
                    según el caso y disponibilidad.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="container pb-5">
    <div class="row g-4">
        <div class="col-lg-6 fade-in-up">
            <div class="mission-card h-100">
                <div class="mini-icon mb-3">❌</div>
                <h3 class="section-title mb-3">Qué no cubre</h3>
                <ul class="styled-list mb-0">
                    <li>Daños por golpes, líquidos, caídas o manipulación inadecuada.</li>
                    <li>Desgaste normal por uso cotidiano del producto.</li>
                    <li>Alteraciones, modificaciones o reparaciones no autorizadas.</li>
                    <li>Fallas ocasionadas por instalaciones incorrectas o uso indebido.</li>
                </ul>
            </div>
        </div>

        <div class="col-lg-6 fade-in-up delay-1">
            <div class="mission-card h-100">
                <div class="mini-icon mb-3">📋</div>
                <h3 class="section-title mb-3">Proceso de garantía</h3>
                <ol class="styled-list mb-0">
                    <li>Contactar a TechStore CR por nuestros medios oficiales.</li>
                    <li>Indicar el problema presentado y brindar datos de la compra.</li>
                    <li>Esperar la validación o revisión correspondiente.</li>
                    <li>Recibir respuesta sobre el procedimiento aplicable al caso.</li>
                </ol>
            </div>
        </div>
    </div>
</section>

<section class="container pb-5">
    <div class="content-card fade-in-up">
        <h2 class="section-title mb-3">Importante</h2>
        <p>
            Cada garantía está sujeta a revisión y aprobación según el tipo de producto,
            estado del artículo y políticas correspondientes. TechStore CR se reserva
            el derecho de validar cada caso antes de emitir una resolución.
        </p>
        <p class="mb-0">
            Si deseas iniciar una consulta o gestión, puedes escribirnos desde la sección de
            <a asp-controller="Home" asp-action="Contactenos" class="inline-page-link">Contáctenos</a>.
        </p>
    </div>
</section>