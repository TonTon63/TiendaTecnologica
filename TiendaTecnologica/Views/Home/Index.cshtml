@{
    ViewData["Title"] = "Inicio";
}

<div id="carouselHome" class="carousel slide" data-bs-ride="carousel">
    <div class="carousel-inner">

        <div class="carousel-item active">
            <div class="carousel-banner d-flex align-items-center">
                <div class="container text-white">
                    <h1 class="fw-bold">Tecnología al mejor precio</h1>
                    <p>Descubre nuestros productos</p>
                </div>
            </div>
        </div>

        <div class="carousel-item">
            <div class="carousel-banner banner-2 d-flex align-items-center">
                <div class="container text-white">
                    <h1 class="fw-bold">Ofertas en Gaming</h1>
                    <p>Equipos y accesorios gamer</p>
                </div>
            </div>
        </div>

        <div class="carousel-item">
            <div class="carousel-banner banner-3 d-flex align-items-center">
                <div class="container text-white">
                    <h1 class="fw-bold">Arma tu PC</h1>
                    <p>Componentes de alto rendimiento</p>
                </div>
            </div>
        </div>

    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#carouselHome" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>

    <button class="carousel-control-next" type="button" data-bs-target="#carouselHome" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<section class="container my-5">
    <h2 class="fw-bold mb-4">Categorías destacadas</h2>

    <div class="row g-4">

        <div class="col-6 col-md-3">
            <a href="/Categorias/Detalle/1" class="text-decoration-none">
                <div class="categoria-home-card">
                    <h5>Computadoras</h5>
                </div>
            </a>
        </div>

        <div class="col-6 col-md-3">
            <a href="/Categorias/Detalle/2" class="text-decoration-none">
                <div class="categoria-home-card">
                    <h5>Periféricos</h5>
                </div>
            </a>
        </div>

        <div class="col-6 col-md-3">
            <a href="/Categorias/Detalle/3" class="text-decoration-none">
                <div class="categoria-home-card">
                    <h5>Audio y Video</h5>
                </div>
            </a>
        </div>

        <div class="col-6 col-md-3">
            <a href="/Categorias/Detalle/6" class="text-decoration-none">
                <div class="categoria-home-card">
                    <h5>Gaming</h5>
                </div>
            </a>
        </div>

    </div>
</section>

<section class="container my-5">
    <h2 class="fw-bold mb-4">Productos destacados</h2>

    <div class="row g-4">

        <div class="col-md-4 col-lg-3">
            <div class="card producto-card h-100 shadow-sm border-0">
                <div class="producto-imagen-placeholder d-flex align-items-center justify-content-center">
                    <span>Imagen</span>
                </div>
                <div class="card-body">
                    <h5>Producto ejemplo</h5>
                    <p class="text-muted">Marca</p>
                    <p class="fw-bold">₡100,000</p>
                </div>
            </div>
        </div>

    </div>
</section>

<section class="beneficios-section text-center py-5">
    <div class="container">
        <div class="row">

            <div class="col-md-4">
                <h5>Envíos rápidos</h5>
                <p>Recibe tus productos en tiempo récord</p>
            </div>

            <div class="col-md-4">
                <h5>Garantía</h5>
                <p>Todos nuestros productos tienen garantía</p>
            </div>

            <div class="col-md-4">
                <h5>Soporte</h5>
                <p>Atención directa por WhatsApp</p>
            </div>

        </div>
    </div>
</section>

<section class="container my-5 text-center">
    <h2 class="fw-bold mb-4">Marcas que nos respaldan</h2>

    <div class="row g-4 justify-content-center">

        <div class="col-4 col-md-2">ASUS</div>
        <div class="col-4 col-md-2">Samsung</div>
        <div class="col-4 col-md-2">HP</div>
        <div class="col-4 col-md-2">Logitech</div>
        <div class="col-4 col-md-2">Kingston</div>

    </div>
</section>


        <section class="bg-light py-5">
    <div class="container text-center">
        <h2 class="fw-bold mb-4">Lo que dicen nuestros clientes</h2>

        <div class="row">

            <div class="col-md-4">
                ⭐⭐⭐⭐⭐
                <p>"Excelente servicio y productos de calidad"</p>
            </div>

            <div class="col-md-4">
                ⭐⭐⭐⭐⭐
                <p>"Muy rápidos en la entrega"</p>
            </div>

            <div class="col-md-4">
                ⭐⭐⭐⭐⭐
                <p>"Recomendado al 100%"</p>
            </div>

        </div>
    </div>
</section>

<section class="suscripcion-section text-white text-center py-5">
    <div class="container">
        <h2 class="fw-bold">Únete a nuestras ofertas exclusivas</h2>
        <p>Recibe promociones antes que nadie</p>

        <form class="d-flex justify-content-center mt-3">
            <input type="email" class="form-control w-50 me-2" placeholder="Tu correo">
            <button class="btn btn-dark">Suscribirme</button>
        </form>
    </div>
</section>