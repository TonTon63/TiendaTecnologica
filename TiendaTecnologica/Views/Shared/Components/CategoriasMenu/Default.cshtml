@model IEnumerable<TiendaTecnologica.Models.Categoria>

<li class="nav-item dropdown categorias-dropdown">
    <a class="nav-link dropdown-toggle"
           href="#"
           id="categoriasDropdown"
           role="button"
           data-bs-toggle="dropdown"
           aria-expanded="false">
        Categorías
    </a>

    <ul class="dropdown-menu categorias-menu" aria-labelledby="categoriasDropdown">
        @foreach (var categoria in Model)
        {
            <li>
                <a class="dropdown-item"
                       asp-controller="Categorias"
                       asp-action="Detalle"
                       asp-route-id="@categoria.IdCategoria">
                    @categoria.Nombre
                </a>
            </li>
        }
    </ul>
</li>